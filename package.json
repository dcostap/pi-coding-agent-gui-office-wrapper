{
  "name": "office-gui-for-agentic-ai",
  "private": true,
  "workspaces": [
    "apps/gateway",
    "apps/tui",
    "apps/gui/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "npm run dev --workspace @office-agent/gateway",
    "start:gateway": "npm run start --workspace @office-agent/gateway",
    "gateway:bootstrap-auth": "npm run bootstrap-auth --workspace @office-agent/gateway",
    "gateway:probe-auth": "npm run probe-auth --workspace @office-agent/gateway",
    "pi:managed": "npm run tui --workspace @office-agent/tui",
    "tui": "npm run tui --workspace @office-agent/tui",
    "gui:dev": "npm run dev --workspace @office-agent/gui",
    "gui:build": "npm run build --workspace @office-agent/gui",
    "sandbox:smoke": "npm run test:sandbox:smoke --workspace @office-agent/gui",
    "sandbox:smoke:workflows": "npm run test:sandbox:workflows --workspace @office-agent/gui",
    "sandbox:smoke:python": "npm run test:sandbox:python --workspace @office-agent/gui",
    "gui:package": "npm run package:win --workspace @office-agent/gui",
    "gui:package:dir": "npm run package:win:dir --workspace @office-agent/gui"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
