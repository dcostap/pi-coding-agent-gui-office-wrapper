{
  "name": "office-gui-for-agentic-ai",
  "private": true,
  "workspaces": [
    "apps/gateway",
    "apps/tui",
    "apps/gui",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "npm run dev --workspace @office-agent/gateway",
    "start:gateway": "npm run start --workspace @office-agent/gateway",
    "gateway:bootstrap-auth": "npm run bootstrap-auth --workspace @office-agent/gateway",
    "gateway:probe-auth": "npm run probe-auth --workspace @office-agent/gateway",
    "gateway:smoke:analytics": "npm run smoke:analytics --workspace @office-agent/gateway",
    "gateway:smoke:vfs": "npm run smoke:vfs --workspace @office-agent/gateway",
    "pi:managed": "npm run tui --workspace @office-agent/tui",
    "tui": "npm run tui --workspace @office-agent/tui",
    "gui:dev": "npm run dev --workspace apps/gui",
    "gui:build": "npm run build --workspace apps/gui",
    "gui:typecheck": "npm run typecheck --workspace apps/gui",
    "gui:test": "npm run test --workspace apps/gui",
    "gui:package": "npm run gui:package:users",
    "gui:package:users": "cargo build --release --manifest-path native/windows-sandbox-helper/Cargo.toml && npm run build:release --workspace apps/gui",
    "gui:package:dir": "npm run build --workspace apps/gui"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
