{
  "name": "howcode",
  "productName": "Castrosua IA",
  "version": "0.1.2",
  "private": true,
  "description": "Desktop coding app for Pi with projects, terminal, git, and diff workflows.",
  "license": "MIT",
  "author": "Igor Warzocha",
  "main": "build/electron/main/index.cjs",
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "bun run dev:clean && concurrently -k \"bun run dev:web\" \"bun run dev:runtime\" \"bun run dev:desktop\"",
    "dev:clean": "rm -rf artifacts/electron build/electron build/desktop build/dev-server.json build/dev-web-bridge.mjs build/dev-web-bridge.mjs.map",
    "prepush:clean": "rm -rf artifacts/electron dist build/electron build/desktop build/dev-server.json build/dev-web-bridge.mjs build/dev-web-bridge.mjs.map",
    "prepush:check": "bun run lint && bun run typecheck",
    "dev:web": "bun ./scripts/dev-web.ts",
    "dev:runtime": "bun ./scripts/build-electron-runtime.ts --watch",
    "dev:desktop": "bun ./scripts/dev-electron.ts",
    "build:runtime": "bun ./scripts/build-electron-runtime.ts",
    "build": "vite build && bun run build:runtime && electron-builder --dir --config electron-builder.yml",
    "build:release": "vite build && bun run build:runtime && electron-builder --config electron-builder.yml --publish never",
    "build:launcher-artifacts": "bun ./scripts/package-launcher-artifacts.ts",
    "release:prepare": "bun run build:release && bun run build:launcher-artifacts",
    "pack:howcode": "cd packages/howcode && npm pack",
    "publish:howcode:dry-run": "cd packages/howcode && npm publish --dry-run",
    "preview": "vite preview",
    "prepare": "test -d .git && husky || true",
    "postinstall": "node -e \"require('electron/install')\" && electron-builder install-app-deps",
    "lint": "biome check --organize-imports-enabled=false .",
    "format": "biome format --write .",
    "typecheck": "bun run typecheck:web && bun run typecheck:desktop && bun run typecheck:electron && bun run typecheck:scripts",
    "typecheck:web": "tsc --noEmit",
    "typecheck:desktop": "tsc -p tsconfig.desktop.json --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run",
    "test:composer": "vitest run src/test/composer",
    "test:watch": "vitest",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cts,mts,cjs,mjs,json,css,md}": [
      "biome check --organize-imports-enabled=false --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/exo-2": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@mariozechner/pi-agent-core": "0.72.0",
    "@mariozechner/pi-ai": "0.72.0",
    "@mariozechner/pi-coding-agent": "0.72.0",
    "@mariozechner/pi-tui": "0.72.0",
    "@mdxeditor/editor": "^3.55.0",
    "@pierre/diffs": "^1.1.0-beta.16",
    "@pierre/trees": "1.0.0-beta.3",
    "@tanstack/react-pacer": "^0.21.1",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@wterm/core": "0.3.0",
    "@wterm/dom": "0.3.0",
    "@wterm/ghostty": "0.3.0",
    "@wterm/react": "0.3.0",
    "better-sqlite3": "^12.2.0",
    "clip-filepaths": "^0.3.0",
    "esbuild": "0.27.7",
    "lucide-react": "^0.525.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sherpa-onnx-node": "^1.12.38",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.1.8",
    "@types/bun": "^1.3.11",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "electron": "41.2.1",
    "electron-builder": "^26.0.12",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.7",
    "react-grab": "^0.1.32",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@aws-sdk/client-bedrock-runtime": "^3.1036.0",
    "@aws-sdk/core": "^3.974.5",
    "@aws-sdk/xml-builder": "^3.972.19",
    "@wterm/core": "0.3.0",
    "@wterm/dom": "0.3.0",
    "uuid": "^14.0.0"
  }
}
